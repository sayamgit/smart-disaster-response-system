{
  "title": "Disaster Response System",
  "uid": "disaster-main",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Active Incidents",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "disaster_active_incidents_total", "legendFormat": "Active Incidents" }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 20 }
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "Available Volunteers",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "disaster_volunteers_available", "legendFormat": "Available" }
      ]
    },
    {
      "id": 3,
      "title": "Request Rate (req/s)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "sum(rate(http_request_duration_seconds_count[1m]))", "legendFormat": "req/s" }
      ]
    },
    {
      "id": 4,
      "title": "Error Rate (%)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count{status_code=~'5..'}[5m])) / sum(rate(http_request_duration_seconds_count[5m])) * 100",
          "legendFormat": "Error %"
        }
      ],
      "options": {
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "HTTP Request Duration (p95)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Requests by Route",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count[5m])) by (route, method)",
          "legendFormat": "{{method}} {{route}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Total Alerts Issued",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum(increase(disaster_alerts_total[5m])) by (severity, type)",
          "legendFormat": "{{severity}} - {{type}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Shelter Occupancy",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 12, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "avg(disaster_shelter_occupancy_ratio)",
          "legendFormat": "Avg Occupancy"
        }
      ],
      "options": {
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.7 },
            { "color": "red", "value": 0.9 }
          ]
        }
      }
    }
  ]
}
